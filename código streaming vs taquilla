# GRÁFICA 1.2: EVOLUCIÓN DE LA TAQUILLA SEMANAL
library(ggplot2)
library(scales)

grafica_taquilla <- ggplot(base_final, aes(x = fecha, y = taquilla_semanal)) +
  geom_line(color = "#8B0000", linewidth = 0.7, alpha = 0.8) +
  geom_smooth(method = "loess", se = FALSE, color = "#1A3C5E", 
              linewidth = 1.2, linetype = "dashed") +
  geom_vline(xintercept = as.Date("2020-03-16"), 
             color = "black", linewidth = 1, linetype = "dashed") +
  annotate("text", x = as.Date("2020-05-01"), y = 450000000,
           label = "Inicio COVID-19\n(mar 2020)", 
           hjust = 0, size = 3.5, color = "black") +
  scale_y_continuous(labels = label_dollar(scale = 1e-6, suffix = "M")) +
  scale_x_date(date_breaks = "1 year", date_labels = "%Y") +
  labs(
    title    = "Gráfica 1.2 Evolución de los ingresos semanales de taquilla en EE.UU. (2015–2022)",
    subtitle = "Línea azul discontinua: tendencia suavizada (LOESS)",
    x        = "",
    y        = "Ingresos semanales (millones USD)",
    caption  = "Fuente: Box Office Mojo"
  ) +
  theme_minimal() +
  theme(
    plot.title    = element_text(face = "bold", size = 11, hjust = 0),
    plot.subtitle = element_text(size = 9, color = "gray50"),
    axis.text     = element_text(size = 9),
    plot.caption  = element_text(size = 8, color = "gray50")
  )

ruta_g1 <- "C:/Users/natal/OneDrive/Personal/Universidad (1)/Noveno semestre/Analítica de datos/Caso Final/grafica_taquilla_semanal.png"
ggsave(ruta_g1, plot = grafica_taquilla, width = 12, height = 6, dpi = 150)

# GRÁFICA 1.3: INGRESOS DE NETFLIX VS TAQUILLA ESTADOUNIDENSE (2015–2022) ANEXO
base_final <- read_excel("C:/Users/natal/OneDrive/Personal/Universidad (1)/Noveno semestre/Analítica de datos/Caso Final/base streaming_taquilla USA.xlsx")
escala <- max(base_final$taquilla_semanal) / max(base_final$ingresos_netflix)

grafica_netflix <- ggplot(base_final, aes(x = fecha)) +
  geom_line(aes(y = taquilla_semanal, color = "Taquilla EE.UU."), linewidth = 0.7, alpha = 0.8) +
  geom_line(aes(y = ingresos_netflix * escala, color = "Ingresos Netflix"), linewidth = 1.2) +
  geom_vline(xintercept = as.Date("2020-03-16"),
             color = "black", linewidth = 1, linetype = "dashed") +
  annotate("text", x = as.Date("2020-05-01"), y = 450000000,
           label = "Inicio COVID-19\n(mar 2020)", hjust = 0, size = 3.5) +
  scale_y_continuous(
    name   = "Taquilla semanal (millones USD)",
    labels = label_dollar(scale = 1e-6, suffix = "M"),
    sec.axis = sec_axis(~ . / escala,
                        name   = "Ingresos Netflix (millones USD)",
                        labels = label_dollar(suffix = "M"))
  ) +
  scale_color_manual(values = c("Taquilla EE.UU." = "#8B0000", "Ingresos Netflix" = "#1A3C5E")) +
  scale_x_date(date_breaks = "1 year", date_labels = "%Y") +
  labs(
    title   = "Gráfica 2. Ingresos de Netflix vs. taquilla estadounidense (2015–2022)",
    x       = "",
    color   = "",
    caption = "Fuente: Box Office Mojo; Netflix Earnings Reports"
  ) +
  theme_minimal() +
  theme(
    plot.title      = element_text(face = "bold", size = 11, hjust = 0),
    axis.text       = element_text(size = 9),
    legend.position = "bottom",
    plot.caption    = element_text(size = 8, color = "gray50")
  )
ruta_g2 <- "C:/Users/natal/OneDrive/Personal/Universidad (1)/Noveno semestre/Analítica de datos/Caso Final/grafica_netflix_vs_taquilla.png"
ggsave(ruta_g2, plot = grafica_netflix, width = 12, height = 6, dpi = 150)


# GRÁFICA 1.4: DISTRIBUCIÓN DE INGRESOS DE TAQUILLA ANTES Y DESPUÉS
#              DEL AJUSTE LOGARÍTMICO
library(patchwork)
base_final <- read_excel("C:/Users/natal/OneDrive/Personal/Universidad (1)/Noveno semestre/Analítica de datos/Caso Final/base streaming_taquilla USA.xlsx")

# Gráfica izquierda — taquilla sin transformar
g_antes <- ggplot(base_final, aes(x = taquilla_semanal)) +
  geom_histogram(fill = "#8B0000", color = "white", bins = 40, alpha = 0.85) +
  scale_x_continuous(labels = label_dollar(scale = 1e-6, suffix = "M")) +
  labs(
    title    = "Antes del logaritmo",
    subtitle = "Taquilla semanal (USD)",
    x        = "Ingresos semanales",
    y        = "Frecuencia"
  ) +
  theme_minimal() +
  theme(
    plot.title    = element_text(face = "bold", size = 11, hjust = 0.5),
    plot.subtitle = element_text(size = 9, color = "gray50", hjust = 0.5),
    axis.text     = element_text(size = 9)
  )

# Gráfica derecha — log taquilla
g_despues <- ggplot(base_final, aes(x = log_taquilla)) +
  geom_histogram(fill = "#1A3C5E", color = "white", bins = 40, alpha = 0.85) +
  labs(
    title    = "Después del logaritmo",
    subtitle = "Log(Taquilla semanal)",
    x        = "Log(Ingresos semanales)",
    y        = "Frecuencia"
  ) +
  theme_minimal() +
  theme(
    plot.title    = element_text(face = "bold", size = 11, hjust = 0.5),
    plot.subtitle = element_text(size = 9, color = "gray50", hjust = 0.5),
    axis.text     = element_text(size = 9)
  )
grafica_log <- g_antes + g_despues +
  plot_annotation(
    title   = "Gráfica 1.4. Distribución de la taquilla antes y después de la transformación logarítmica",
    caption = "Fuente: Box Office Mojo",
    theme   = theme(
      plot.title   = element_text(face = "bold", size = 11, hjust = 0.5),
      plot.caption = element_text(size = 8, color = "gray50")
    )
  )
ruta_g3 <- "C:/Users/natal/OneDrive/Personal/Universidad (1)/Noveno semestre/Analítica de datos/Caso Final/grafica_distribucion_log.png"
ggsave(ruta_g3, plot = grafica_log, width = 12, height = 6, dpi = 150) 
